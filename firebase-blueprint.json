{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["tenant", "landlord", "agent"], "description": "User role" },
        "isVerified": { "type": "boolean", "description": "Whether the landlord/agent is verified" },
        "rating": { "type": "number", "description": "Average rating for landlords/agents" },
        "reviewCount": { "type": "number", "description": "Number of reviews received" },
        "phoneNumber": { "type": "string", "description": "Contact phone number" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "House listing information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the property" },
        "title": { "type": "string", "description": "Title of the listing" },
        "description": { "type": "string", "description": "Detailed description" },
        "location": { "type": "string", "description": "Location (e.g., Kilimani, Nairobi)" },
        "price": { "type": "number", "description": "Monthly rent in KSh" },
        "type": { "type": "string", "enum": ["apartment", "house", "studio", "bedsitter"], "description": "Type of property" },
        "bedrooms": { "type": "number", "description": "Number of bedrooms" },
        "bathrooms": { "type": "number", "description": "Number of bathrooms" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "List of image URLs" },
        "ownerId": { "type": "string", "description": "UID of the landlord or agent" },
        "ownerType": { "type": "string", "enum": ["landlord", "agent"], "description": "Whether listed by landlord or agent" },
        "status": { "type": "string", "enum": ["available", "rented", "pending"], "description": "Current status" },
        "amenities": { "type": "array", "items": { "type": "string" }, "description": "List of amenities (WiFi, Parking, etc.)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Listing date" }
      },
      "required": ["id", "title", "location", "price", "ownerId", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "Tenant application for a property",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the application" },
        "propertyId": { "type": "string", "description": "ID of the property being applied for" },
        "tenantId": { "type": "string", "description": "UID of the tenant" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Application status" },
        "message": { "type": "string", "description": "Optional message from the tenant" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Application date" }
      },
      "required": ["id", "propertyId", "tenantId", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Rating and review for an agent or landlord",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the review" },
        "targetId": { "type": "string", "description": "UID of the agent or landlord being reviewed" },
        "reviewerId": { "type": "string", "description": "UID of the tenant giving the review" },
        "rating": { "type": "number", "description": "Rating score (1-5)" },
        "comment": { "type": "string", "description": "Review comment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Review date" }
      },
      "required": ["id", "targetId", "reviewerId", "rating"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment record for deposit or rent",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the payment" },
        "userId": { "type": "string", "description": "UID of the user making the payment" },
        "propertyId": { "type": "string", "description": "ID of the property" },
        "amount": { "type": "number", "description": "Amount paid in KSh" },
        "purpose": { "type": "string", "enum": ["deposit", "rent"], "description": "Purpose of payment" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "Payment status" },
        "transactionId": { "type": "string", "description": "External transaction ID (e.g., M-Pesa code)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Payment date" }
      },
      "required": ["id", "userId", "propertyId", "amount", "purpose", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/properties/{propertyId}": { "schema": "Property", "description": "House listings" },
    "/properties/{propertyId}/applications/{applicationId}": { "schema": "Application", "description": "Applications for a specific property" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Agent and landlord reviews" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records" }
  }
}
